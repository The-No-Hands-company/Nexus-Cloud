# Nexus Cloud environment variables
# Copy this file to .env and fill in values before running

# HTTP server port (default: 8787)
PORT=8787

# API key for authenticating mutating requests (POST/PATCH/DELETE).
# Leave empty to run without auth (development only — never in production).
NEXUS_CLOUD_API_KEY=change-me

# CORS allowed origin. Use a specific domain in production.
CORS_ORIGIN=*

# Base domain used when generating public subdomain addresses.
# Example: nexus.cloud  →  mysite.nexus.cloud
# You need a wildcard DNS record: *.nexus.cloud → IP of your reverse proxy
NEXUS_CLOUD_DOMAIN=nexus.local

# Public URL where this Nexus Cloud instance is reachable.
# Returned in /.well-known/nexus-cloud so other NS tools can discover it.
NEXUS_CLOUD_URL=https://nexus.cloud

# Email for Let's Encrypt certificate registration (used by Caddy).
# Required in production so Let's Encrypt can contact you about your certs.
ACME_EMAIL=admin@example.com

# Optional: Nexus Deploy integration
NEXUS_DEPLOY_URL=
NEXUS_DEPLOY_TOKEN=
