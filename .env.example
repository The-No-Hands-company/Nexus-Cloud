# Nexus Cloud environment variables
# Copy this file to .env and fill in values before running

# HTTP server port (default: 8787)
PORT=8787

# API key for authenticating mutating requests (POST/PATCH/DELETE).
# Leave empty to run without auth (development only — never in production).
NEXUS_CLOUD_API_KEY=change-me

# CORS allowed origin. Use a specific domain in production.
CORS_ORIGIN=*

# Base domain used when generating public subdomain addresses.
# Example: nexus.cloud  →  mysite.nexus.cloud
# You need a wildcard DNS record: *.nexus.cloud → IP of your reverse proxy
NEXUS_CLOUD_DOMAIN=nexus.local

# Public URL where this Nexus Cloud instance is reachable.
# Returned in /.well-known/nexus-cloud so other NS tools can discover it.
NEXUS_CLOUD_URL=https://nexus.cloud

# Public IPv4 of this server.
# Used when generating DNS A records (Cloudflare bootstrap or CoreDNS zone file).
SERVER_PUBLIC_IP=1.2.3.4

# ── Path A: Cloudflare DNS (recommended for getting started) ─────────────────
# Create an API token at https://dash.cloudflare.com/profile/api-tokens with:
#   Zone: DNS: Edit — for your specific zone
# Find your Zone ID on the domain Overview tab in the Cloudflare dashboard.
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-cloudflare-zone-id
# After setting these, run: POST /api/v1/dns/bootstrap
# This creates (or updates) nexus.cloud A <IP> and *.nexus.cloud A <IP>.

# ── Path B: Sovereign CoreDNS (no DNS provider needed) ───────────────────────
# At your registrar, change the domain's nameservers to ns1.nexus.cloud and
# ns2.nexus.cloud, then add glue records pointing both to SERVER_PUBLIC_IP.
# Then start CoreDNS alongside Nexus Cloud:
#   docker compose --profile sovereign up
# Nexus Cloud writes /app/data/dns/nexus.zone (auto-reloaded every 30s).

# Email for Let's Encrypt certificate registration (used by Caddy).
# Required in production so Let's Encrypt can contact you about your certs.
ACME_EMAIL=admin@example.com

# Optional: Nexus Deploy integration
NEXUS_DEPLOY_URL=
NEXUS_DEPLOY_TOKEN=
