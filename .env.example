# Nexus Cloud environment variables
# Copy this file to .env and fill in values before running
#
# Nexus Systems Ecosystem is sovereign, self-hosted, and federated.
# The default stack (docker compose up) runs its own authoritative DNS via CoreDNS.
# No third-party DNS provider is needed after the one-time nameserver delegation step.

# HTTP server port (default: 8787)
PORT=8787

# API key for authenticating mutating requests (POST/PATCH/DELETE).
# Leave empty to run without auth (development only -- never in production).
NEXUS_CLOUD_API_KEY=change-me

# CORS allowed origin. Use a specific domain in production.
CORS_ORIGIN=*

# Base domain used when generating public subdomain addresses.
# Example: nexus.cloud  ->  mysite.nexus.cloud
NEXUS_CLOUD_DOMAIN=nexus.cloud

# Public URL where this Nexus Cloud instance is reachable.
# Returned in /.well-known/nexus-cloud so other NS tools can discover it.
NEXUS_CLOUD_URL=https://nexus.cloud

# Public IPv4 of this server.
# Written into the CoreDNS zone file as the A record for ns1, ns2, and the wildcard.
SERVER_PUBLIC_IP=1.2.3.4

# Email for Let's Encrypt certificate registration (used by Caddy).
# Required in production so Let's Encrypt can contact you about your certs.
ACME_EMAIL=admin@example.com

# ── Sovereign DNS (default) ───────────────────────────────────────────────────
# CoreDNS runs as part of the default stack and serves the zone file that
# Nexus Cloud generates at startup. No extra config needed here.
#
# One-time registrar setup (do this before going live):
#   1. Change the domain's nameservers to:
#        ns1.nexus.cloud
#        ns2.nexus.cloud
#   2. Add glue A records at the registrar (so the internet can find ns1/ns2):
#        ns1.nexus.cloud  A  <SERVER_PUBLIC_IP>
#        ns2.nexus.cloud  A  <SERVER_PUBLIC_IP>
#
# After DNS propagation (up to 48h), your server IS the DNS authority.
# Every new NS tool that registers with Nexus Cloud gets a subdomain instantly --
# no API calls, no provider limits, no third-party dependency.

# ── Cloudflare DNS bootstrap (optional, transition only) ─────────────────────
# Only needed if you want the domain reachable *before* glue records have
# propagated (i.e. while still on Cloudflare nameservers temporarily).
# Once CoreDNS is authoritative, delete these values.
# Token needs: Zone: DNS: Edit -- for your specific zone only.
CF_API_TOKEN=
CF_ZONE_ID=

# Optional: Nexus Deploy integration
NEXUS_DEPLOY_URL=
NEXUS_DEPLOY_TOKEN=
