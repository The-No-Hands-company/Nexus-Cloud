# CoreDNS Corefile — sovereign authoritative DNS for Nexus Cloud
#
# This is the "Path B" setup: Nexus Cloud IS the authoritative nameserver
# for its own domain. No DNS provider needed after the one-time glue record step.
#
# Glue record setup (one-time, at your registrar):
#   1. Change the domain's nameservers to:  ns1.nexus.cloud  ns2.nexus.cloud
#      (for redundancy, ns2 points to the same server initially; you can add
#       a second node later)
#   2. Create glue records at the registrar:
#        ns1.nexus.cloud  A  <SERVER_PUBLIC_IP>
#        ns2.nexus.cloud  A  <SERVER_PUBLIC_IP>
#
# After propagation (up to 48h), all *.nexus.cloud queries will reach CoreDNS
# on this server. The zone file is generated by Nexus Cloud from its routing
# table and reloaded automatically every 30 seconds.
#
# For LAN/dev: set the env vars and run `docker compose --profile sovereign up`

# ── Authoritative zone for the cloud domain ────────────────────────────────────
{$NEXUS_CLOUD_DOMAIN:nexus.local} {
    # Serve the zone from a file Nexus Cloud writes into the shared volume.
    # CoreDNS checks the SOA serial and reloads when it changes.
    file /data/dns/nexus.zone {
        reload 30s
    }
    log
    errors
}

# ── Catch-all forward for anything that isn't our domain ──────────────────────
# CoreDNS only answers for nexus.cloud; all other queries are forwarded upstream.
. {
    forward . 1.1.1.1 1.0.0.1 8.8.8.8 {
        prefer_udp
    }
    cache 300
    log
    errors
}
